{
  "expo": {
    "name": "BudgetTracker",
    "slug": "budget-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.budgettracker.app"
    },
    "android": {
      "package": "com.budgettracker.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-font",
        {
          "fonts": []
        }
      ]
    ],
    "scheme": "budgettracker",
    "experiments": {
      "typedRoutes": true
    }
  }
}
